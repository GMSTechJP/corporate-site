---
// お知らせ詳細ページ
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const news = await getCollection("news", ({ data }) => !data.draft);
  return news.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"news">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL;

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(d);

const categoryLabel: Record<string, string> = {
  news: "お知らせ",
  release: "リリース",
  event: "イベント",
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description ?? entry.data.title}
>
  <article class="section">
    <div class="container container-narrow">
      <a href={`${base}news/`} class="back-link">← お知らせ一覧へ</a>

      <header class="news-detail__header">
        <div class="news-detail__meta">
          <time datetime={entry.data.date.toISOString()}>
            {formatDate(entry.data.date)}
          </time>
          <span class="news-detail__cat">
            {categoryLabel[entry.data.category] ?? entry.data.category}
          </span>
        </div>
        <h1>{entry.data.title}</h1>
      </header>

      <div class="prose">
        <Content />
      </div>

      <hr />

      <a href={`${base}news/`} class="back-link">← お知らせ一覧へ</a>
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .news-detail__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .news-detail__meta {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
  }

  .news-detail__meta time {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .news-detail__cat {
    font-size: 0.75rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.22rem 0.55rem;
    border-radius: 4px;
    color: var(--color-text-muted);
  }

  .news-detail__header h1 {
    font-size: clamp(1.6rem, 1.5vw + 1rem, 2rem);
    margin: 0;
  }
</style>
