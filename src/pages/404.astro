---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ページが見つかりません" description="お探しのページは見つかりませんでした。">
  <section class="section">
    <div class="container container-narrow not-found">
      <p class="eyebrow">404</p>
      <h1>ページが見つかりません</h1>
      <p>
        お探しのページは移動・削除されたか、URLが正しくない可能性があります。
      </p>
      <p>
        <a class="btn btn--primary" href="/">トップへ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 2rem 0;
  }

  .not-found h1 {
    margin: 0.5rem 0 1rem;
  }

  .not-found p {
    color: var(--color-text-muted);
  }
</style>
