---
// Heroビジュアル案A: 双方向データフロー図
// 取得方向: 現場のデバイス(カメラ/センサー) → エッジ機器 → クラウド → ダッシュボード
// 制御方向: ダッシュボード → クラウド → エッジ機器 → 設備
// 控えめなアニメーション付き
---

<svg
  viewBox="0 0 460 368"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="hero-a-title hero-a-desc"
  class="hero-visual"
>
  <title id="hero-a-title">IoTシステムの双方向データフロー</title>
  <desc id="hero-a-desc">
    現場のセンサーやカメラからエッジ機器、クラウド、ダッシュボードへとデータが流れるとともに、
    ダッシュボードからの遠隔操作やエッジによる自動制御で設備が動作する様子を示した図
  </desc>

  <defs>
    <pattern id="dotsA" width="20" height="20" patternUnits="userSpaceOnUse">
      <circle cx="2" cy="2" r="1" fill="#e4e4e7"></circle>
    </pattern>
  </defs>

  <!-- 背景の控えめなドットパターン -->
  <rect width="460" height="368" fill="url(#dotsA)" opacity="0.5"></rect>

  <!-- ===== 接続ライン ===== -->
  <!-- カメラ → エッジ -->
  <line x1="120" y1="100" x2="220" y2="160" stroke="#c8c8cf" stroke-width="1.2"></line>
  <!-- センサー → エッジ -->
  <line x1="120" y1="184" x2="220" y2="184" stroke="#c8c8cf" stroke-width="1.2"></line>
  <!-- エッジ → 設備 (制御方向) -->
  <line x1="220" y1="208" x2="120" y2="268" stroke="#c8c8cf" stroke-width="1.2"></line>
  <!-- エッジ ⇔ クラウド (双方向) -->
  <line x1="290" y1="184" x2="370" y2="116" stroke="#c8c8cf" stroke-width="1.2"></line>
  <!-- クラウド ⇔ ダッシュボード (双方向) -->
  <line x1="412" y1="116" x2="412" y2="224" stroke="#c8c8cf" stroke-width="1.2"></line>

  <!-- ===== 取得方向のドット (青塗り) ===== -->
  <circle r="3" fill="#1d4ed8">
    <animateMotion dur="2.5s" repeatCount="indefinite" path="M120,100 L220,160"></animateMotion>
  </circle>
  <circle r="3" fill="#1d4ed8">
    <animateMotion dur="3.0s" begin="0.4s" repeatCount="indefinite" path="M120,184 L220,184"></animateMotion>
  </circle>
  <circle r="3" fill="#1d4ed8">
    <animateMotion dur="2.8s" begin="0.9s" repeatCount="indefinite" path="M290,184 L370,116"></animateMotion>
  </circle>
  <circle r="3" fill="#1d4ed8">
    <animateMotion dur="3.0s" begin="1.4s" repeatCount="indefinite" path="M412,116 L412,224"></animateMotion>
  </circle>

  <!-- ===== 制御方向のドット (オレンジ抜き、遠隔操作・自動制御) ===== -->
  <!-- ダッシュボード → クラウド -->
  <circle r="3" fill="white" stroke="#d97706" stroke-width="1.6">
    <animateMotion dur="3.2s" begin="1.0s" repeatCount="indefinite" path="M412,224 L412,116"></animateMotion>
  </circle>
  <!-- クラウド → エッジ -->
  <circle r="3" fill="white" stroke="#d97706" stroke-width="1.6">
    <animateMotion dur="2.9s" begin="1.7s" repeatCount="indefinite" path="M370,116 L290,184"></animateMotion>
  </circle>
  <!-- エッジ → 設備 -->
  <circle r="3" fill="white" stroke="#d97706" stroke-width="1.6">
    <animateMotion dur="3.0s" begin="2.4s" repeatCount="indefinite" path="M220,208 L120,268"></animateMotion>
  </circle>

  <!-- ===== デバイス1: カメラ (左上) ===== -->
  <g transform="translate(40,80)">
    <rect width="80" height="40" rx="6" fill="white" stroke="#c8c8cf" stroke-width="1"></rect>
    <circle cx="40" cy="14" r="6" fill="none" stroke="#111114" stroke-width="1.4"></circle>
    <circle cx="40" cy="14" r="2.5" fill="#1d4ed8">
      <animate attributeName="opacity" values="1;0.4;1" dur="2.4s" repeatCount="indefinite"></animate>
    </circle>
    <text x="40" y="32" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#111114" font-weight="600">カメラ</text>
  </g>

  <!-- ===== デバイス2: センサー (左中) ===== -->
  <g transform="translate(40,164)">
    <rect width="80" height="40" rx="6" fill="white" stroke="#c8c8cf" stroke-width="1"></rect>
    <rect x="33" y="6" width="14" height="14" rx="2" fill="none" stroke="#111114" stroke-width="1.4"></rect>
    <line x1="36" y1="10" x2="44" y2="10" stroke="#1d4ed8" stroke-width="1.2"></line>
    <line x1="36" y1="13" x2="44" y2="13" stroke="#1d4ed8" stroke-width="1.2"></line>
    <line x1="36" y1="16" x2="41" y2="16" stroke="#1d4ed8" stroke-width="1.2"></line>
    <text x="40" y="32" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#111114" font-weight="600">センサー</text>
  </g>

  <!-- ===== デバイス3: 設備 (左下、エアコン/照明など制御対象) ===== -->
  <g transform="translate(40,248)">
    <rect width="80" height="40" rx="6" fill="white" stroke="#c8c8cf" stroke-width="1"></rect>
    <!-- エアコン風の本体 -->
    <g transform="translate(28,7)">
      <rect width="24" height="13" rx="2" fill="#f7f7f8" stroke="#111114" stroke-width="1.3"></rect>
      <line x1="3" y1="4" x2="21" y2="4" stroke="#111114" stroke-width="0.9" opacity="0.6"></line>
      <line x1="3" y1="7" x2="21" y2="7" stroke="#111114" stroke-width="0.9" opacity="0.6"></line>
      <line x1="3" y1="10" x2="17" y2="10" stroke="#111114" stroke-width="0.9" opacity="0.6"></line>
      <!-- 動作中インジケーター -->
      <circle cx="20" cy="10" r="1.2" fill="#d97706">
        <animate attributeName="opacity" values="0.3;1;0.3" dur="2.5s" repeatCount="indefinite"></animate>
      </circle>
    </g>
    <text x="40" y="32" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#111114" font-weight="600">設備</text>
  </g>

  <!-- ===== エッジ機器: Raspberry Pi 風チップ (中央) ===== -->
  <g transform="translate(220,144)">
    <rect width="70" height="80" rx="8" fill="#111114"></rect>
    <!-- SoC -->
    <rect x="12" y="12" width="46" height="32" rx="3" fill="#1d4ed8"></rect>
    <text x="35" y="33" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="12" fill="white" font-weight="700">エッジ</text>
    <!-- ピン端子 -->
    <g fill="#5f5e5a">
      <rect x="12" y="56" width="6" height="3"></rect>
      <rect x="22" y="56" width="6" height="3"></rect>
      <rect x="32" y="56" width="6" height="3"></rect>
      <rect x="42" y="56" width="6" height="3"></rect>
      <rect x="52" y="56" width="6" height="3"></rect>
      <rect x="12" y="63" width="6" height="3"></rect>
      <rect x="22" y="63" width="6" height="3"></rect>
      <rect x="32" y="63" width="6" height="3"></rect>
      <rect x="42" y="63" width="6" height="3"></rect>
      <rect x="52" y="63" width="6" height="3"></rect>
    </g>
    <!-- ステータスLED -->
    <circle cx="62" cy="6" r="2.5" fill="#1d4ed8">
      <animate attributeName="opacity" values="0.4;1;0.4" dur="1.6s" repeatCount="indefinite"></animate>
    </circle>
  </g>

  <!-- ===== クラウド (右上) ===== -->
  <g transform="translate(370,76)">
    <path
      d="M14,40 a18,18 0 0 1 4,-35 a16,16 0 0 1 30,-2 a14,14 0 0 1 22,12 a14,14 0 0 1 -8,25 z"
      fill="white"
      stroke="#c8c8cf"
      stroke-width="1.4"
    ></path>
    <text x="38" y="30" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#111114" font-weight="600">AWS</text>
  </g>

  <!-- ===== ダッシュボード (右下) ===== -->
  <g transform="translate(370,224)">
    <rect width="76" height="52" rx="6" fill="white" stroke="#c8c8cf" stroke-width="1"></rect>
    <!-- ヘッダーライン -->
    <line x1="6" y1="12" x2="40" y2="12" stroke="#888780" stroke-width="1.2"></line>
    <line x1="6" y1="16" x2="28" y2="16" stroke="#c8c8cf" stroke-width="1"></line>
    <!-- 棒グラフ -->
    <g fill="#1d4ed8">
      <rect x="6" y="38" width="6" height="8">
        <animate attributeName="height" values="8;14;8" dur="3s" repeatCount="indefinite"></animate>
        <animate attributeName="y" values="38;32;38" dur="3s" repeatCount="indefinite"></animate>
      </rect>
      <rect x="16" y="32" width="6" height="14">
        <animate attributeName="height" values="14;20;14" dur="3.4s" repeatCount="indefinite"></animate>
        <animate attributeName="y" values="32;26;32" dur="3.4s" repeatCount="indefinite"></animate>
      </rect>
      <rect x="26" y="26" width="6" height="20">
        <animate attributeName="height" values="20;28;20" dur="2.8s" repeatCount="indefinite"></animate>
        <animate attributeName="y" values="26;18;26" dur="2.8s" repeatCount="indefinite"></animate>
      </rect>
      <rect x="36" y="22" width="6" height="24"></rect>
      <rect x="46" y="18" width="6" height="28"></rect>
      <rect x="56" y="14" width="6" height="32"></rect>
    </g>
  </g>

  <!-- ===== セクションラベル ===== -->
  <text x="80" y="64" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#888780" letter-spacing="0.5">現場のデバイス</text>
  <text x="255" y="132" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#888780" letter-spacing="0.5">エッジ機器</text>
  <text x="408" y="64" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#888780" letter-spacing="0.5">クラウド</text>
  <text x="408" y="290" text-anchor="middle" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="11" fill="#888780" letter-spacing="0.5">ダッシュボード</text>

  <!-- ===== 凡例 ===== -->
  <g transform="translate(125,348)" font-family="system-ui, -apple-system, 'Hiragino Sans', sans-serif" font-size="10" fill="#666666">
    <circle cx="0" cy="-3" r="3" fill="#1d4ed8"></circle>
    <text x="9" y="0">データ取得</text>
    <circle cx="86" cy="-3" r="3" fill="white" stroke="#d97706" stroke-width="1.6"></circle>
    <text x="95" y="0">遠隔操作・自動制御</text>
  </g>
</svg>

<style>
  .hero-visual {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* アニメーションを「動きを抑えたい」設定にしている人には停止 */
  @media (prefers-reduced-motion: reduce) {
    .hero-visual circle,
    .hero-visual rect {
      animation: none !important;
    }
    .hero-visual animateMotion,
    .hero-visual animate {
      display: none;
    }
  }
</style>
